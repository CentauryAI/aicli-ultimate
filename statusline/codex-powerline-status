#!/usr/bin/env bash
set -u

line="${1:-1}"
pane="${2:-${TMUX_PANE:-}}"
server="${3:-}"
base="#1a1b26"
cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/aicli-ultimate"
config_root="${XDG_CONFIG_HOME:-$HOME/.config}/aicli-ultimate"
mkdir -p "$cache_root"
cache_identity="${server:+$server:}$pane"
pane_key="${cache_identity//[^a-zA-Z0-9]/_}"
cache="$cache_root/status-${pane_key:-default}"
lock_dir="$cache.lock"
owner_file="$lock_dir/owner"

safe() {
  local value="${1//$'\n'/ }"
  value="${value//$'\r'/ }"
  value="${value//#/##}"
  printf '%s' "$value"
}

compact_number() {
  awk -v n="${1:-0}" 'BEGIN {
    if (n >= 1000000) printf "%.1fM", n / 1000000;
    else if (n >= 1000) printf "%.1fk", n / 1000;
    else printf "%d", n;
  }'
}

bar() {
  local pct="${1:-0}" width="${2:-10}" full empty i
  (( pct < 0 )) && pct=0
  (( pct > 100 )) && pct=100
  full=$((pct * width / 100))
  empty=$((width - full))
  for ((i=0; i<full; i++)); do printf '█'; done
  for ((i=0; i<empty; i++)); do printf '░'; done
}

uppercase() {
  printf '%s' "$1" | tr '[:lower:]' '[:upper:]'
}

epoch_time() {
  local epoch="$1" format="$2"
  date -d "@$epoch" "+$format" 2>/dev/null \
    || date -r "$epoch" "+$format" 2>/dev/null \
    || true
}

mtime() {
  local value
  value="$(stat -c %Y "$1" 2>/dev/null)" \
    || value="$(stat -f %m "$1" 2>/dev/null)" \
    || value=0
  [[ "$value" =~ ^[0-9]+$ ]] || value=0
  printf '%s' "$value"
}

powerline() {
  local first=1 previous="" color fg value
  while (( $# >= 3 )); do
    color="$1"; fg="$2"; value="$3"; shift 3
    if (( first )); then
      printf '#[fg=%s,bg=%s]' "$color" "$base"
      first=0
    else
      printf '#[fg=%s,bg=%s]' "$previous" "$color"
    fi
    printf '#[fg=%s,bg=%s,bold] %s #[nobold]' "$fg" "$color" "$(safe "$value")"
    previous="$color"
  done
  (( first )) || printf '#[fg=%s,bg=%s]#[default]' "$previous" "$base"
}

generate() {
  local cwd rollout model effort sql_cwd row metrics codex_home
  cwd="$PWD"
  if [[ -n "$pane" ]]; then
    cwd="$(tmux display-message -p -t "$pane" '#{pane_current_path}' 2>/dev/null || printf '%s' "$PWD")"
  fi

  sql_cwd="${cwd//\'/\'\'}"
  codex_home="${CODEX_HOME:-$HOME/.codex}"
  row=""
  if command -v sqlite3 >/dev/null 2>&1 && [[ -r "$codex_home/state_5.sqlite" ]]; then
    row="$(sqlite3 -separator $'\t' "$codex_home/state_5.sqlite" \
      "select rollout_path,coalesce(model,''),coalesce(reasoning_effort,''),tokens_used from threads where cwd='$sql_cwd' and archived=0 order by updated_at_ms desc,updated_at desc limit 1;" 2>/dev/null || true)"
  fi
  IFS=$'\t' read -r rollout model effort _ <<<"$row"
  model="${model:-Codex}"
  effort="${effort:-xhigh}"

  metrics='{}'
  if command -v jq >/dev/null 2>&1 && [[ -n "${rollout:-}" && -r "$rollout" ]]; then
    metrics="$(tail -n 1200 "$rollout" 2>/dev/null | jq -cs '
      map(select(.type == "event_msg" and .payload.type == "token_count"))
      | (last // {}) | .payload // {}
    ' 2>/dev/null || printf '{}')"
  fi

  local input output cached current window ctx_pct primary weekly reset5 reset7
  input=0 output=0 cached=0 current=0 window=0 primary=0 weekly=0 reset5=0 reset7=0
  if command -v jq >/dev/null 2>&1; then
    input="$(jq -r '.info.total_token_usage.input_tokens // 0' <<<"$metrics")"
    output="$(jq -r '.info.total_token_usage.output_tokens // 0' <<<"$metrics")"
    cached="$(jq -r '.info.total_token_usage.cached_input_tokens // 0' <<<"$metrics")"
    current="$(jq -r '.info.last_token_usage.total_tokens // 0' <<<"$metrics")"
    window="$(jq -r '.info.model_context_window // 0' <<<"$metrics")"
    primary="$(jq -r '.rate_limits.primary.used_percent // 0 | floor' <<<"$metrics")"
    weekly="$(jq -r '.rate_limits.secondary.used_percent // 0 | floor' <<<"$metrics")"
    reset5="$(jq -r '.rate_limits.primary.resets_at // 0' <<<"$metrics")"
    reset7="$(jq -r '.rate_limits.secondary.resets_at // 0' <<<"$metrics")"
  fi
  ctx_pct="$(awk -v used="$current" -v total="$window" 'BEGIN { if (total > 0) printf "%d", used * 100 / total; else print 0 }')"
  [[ "$reset5" != 0 ]] && reset5="$(epoch_time "$reset5" '%H:%M')" || reset5="--:--"
  [[ "$reset7" != 0 ]] && reset7="$(epoch_time "$reset7" '%a %H:%M')" || reset7="--- --:--"
  reset5="${reset5:---:--}"
  reset7="${reset7:---- --:--}"

  local branch changes caveman ponytail cwd_short
  branch="$(git -C "$cwd" branch --show-current 2>/dev/null || true)"
  [[ -n "$branch" ]] || branch="no-git"
  changes="$(git -C "$cwd" status --porcelain --untracked-files=normal 2>/dev/null | wc -l | tr -d ' ')"
  caveman="$(sed -n 's/^caveman=//p' "$config_root/modes" 2>/dev/null | head -1 | tr -cd 'a-zA-Z0-9-' || true)"
  ponytail="$(sed -n 's/^ponytail=//p' "$config_root/modes" 2>/dev/null | head -1 | tr -cd 'a-zA-Z0-9-' || true)"
  if [[ "$cwd" == "$HOME"* ]]; then cwd_short="~${cwd#$HOME}"; else cwd_short="$cwd"; fi

  if [[ -n "$caveman" && -n "$ponytail" ]]; then
    powerline '#7aa2f7' '#1a1b26' "◆ $model [$effort]" '#3d59a1' '#c0caf5' "󰉋 $cwd_short" '#2ac3de' '#1a1b26' " $branch  Δ$changes" '#e0af68' '#1a1b26' "CAVEMAN:$(uppercase "$caveman")" '#9ece6a' '#1a1b26' "PONYTAIL:$(uppercase "$ponytail")"
  elif [[ -n "$caveman" ]]; then
    powerline '#7aa2f7' '#1a1b26' "◆ $model [$effort]" '#3d59a1' '#c0caf5' "󰉋 $cwd_short" '#2ac3de' '#1a1b26' " $branch  Δ$changes" '#e0af68' '#1a1b26' "CAVEMAN:$(uppercase "$caveman")"
  elif [[ -n "$ponytail" ]]; then
    powerline '#7aa2f7' '#1a1b26' "◆ $model [$effort]" '#3d59a1' '#c0caf5' "󰉋 $cwd_short" '#2ac3de' '#1a1b26' " $branch  Δ$changes" '#9ece6a' '#1a1b26' "PONYTAIL:$(uppercase "$ponytail")"
  else
    powerline '#7aa2f7' '#1a1b26' "◆ $model [$effort]" '#3d59a1' '#c0caf5' "󰉋 $cwd_short" '#2ac3de' '#1a1b26' " $branch  Δ$changes"
  fi
  printf '\n'
  powerline '#bb9af7' '#1a1b26' "CTX $(bar "$ctx_pct") ${ctx_pct}%" '#7dcfff' '#1a1b26' "IN $(compact_number "$input")" '#7aa2f7' '#1a1b26' "OUT $(compact_number "$output")" '#565f89' '#c0caf5' "CACHE $(compact_number "$cached")"
  printf '\n'
  powerline '#e0af68' '#1a1b26' "5H $(bar "$primary" 8) ${primary}% ↻$reset5" '#f7768e' '#1a1b26' "7D $(bar "$weekly" 8) ${weekly}% ↻$reset7"
  printf '\n'
}

now=$(date +%s)
modified=$(mtime "$cache")
if (( now - modified >= 10 )); then
  lock_modified=$(mtime "$lock_dir")
  if [[ -d "$lock_dir" ]] && (( now - lock_modified >= 30 )); then
    lock_owner="$(cat "$owner_file" 2>/dev/null || true)"
    owner_pid="${lock_owner%%:*}"
    if [[ ! "$owner_pid" =~ ^[0-9]+$ ]] || ! kill -0 "$owner_pid" 2>/dev/null; then
      if [[ "$(cat "$owner_file" 2>/dev/null || true)" == "$lock_owner" ]]; then
        rm -f "$owner_file"
        if rmdir "$lock_dir" 2>/dev/null && [[ "$owner_pid" =~ ^[0-9]+$ ]]; then
          rm -f "$cache.tmp.$owner_pid"
        fi
      fi
    fi
  fi
  if mkdir "$lock_dir" 2>/dev/null; then
    lock_token="$$:$now:$RANDOM"
    printf '%s\n' "$lock_token" >"$owner_file"
    tmp="$cache.tmp.$$"
    cleanup_status_lock() {
      [[ -n "${tmp:-}" ]] && rm -f "$tmp"
      if [[ -n "${lock_token:-}" \
        && "$(cat "$owner_file" 2>/dev/null || true)" == "$lock_token" ]]; then
        rm -f "$owner_file"
        rmdir "$lock_dir" 2>/dev/null || true
      fi
    }
    trap cleanup_status_lock EXIT
    generate >"$tmp"
    mv "$tmp" "$cache"
    tmp=""
    cleanup_status_lock
    trap - EXIT
  elif [[ ! -r "$cache" ]]; then
    generate | sed -n "${line}p"
    exit 0
  fi
fi
sed -n "${line}p" "$cache"
