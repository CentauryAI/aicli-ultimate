#!/usr/bin/env bash
set -euo pipefail

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
config_root="${XDG_CONFIG_HOME:-$HOME/.config}/aicli-ultimate"
codex_shim="$config_root/codex-bin/codex"
tmux_config="$config_root/tmux.conf"
mode_file="$config_root/modes"
profile="${AICLI_ULTIMATE_PROFILE:-aicli-ultimate}"
profile_args=(--profile "$profile")

resolve_real_codex() {
  local candidate
  if [[ -n "${CODEX_REAL_BIN:-}" ]]; then
    printf '%s\n' "$CODEX_REAL_BIN"
    return
  fi
  while IFS= read -r candidate; do
    [[ -e "$candidate" && "$candidate" -ef "$0" ]] && continue
    [[ -e "$codex_shim" && "$candidate" -ef "$codex_shim" ]] && continue
    printf '%s\n' "$candidate"
    return
  done < <(type -aP codex 2>/dev/null || true)
}

real_codex="$(resolve_real_codex)"
codex_shim_dir="$(dirname "$codex_shim")"
[[ ":$PATH:" == *":$codex_shim_dir:"* ]] || export PATH="$codex_shim_dir:$PATH"

doctor() {
  local value missing=()
  printf 'AI CLI Ultimate / Codex\n'
  [[ -f "$CODEX_HOME/aicli-ultimate.config.toml" ]] \
    && printf '  profile: installed\n' || printf '  profile: missing\n'
  [[ -f "$CODEX_HOME/themes/midnight-blue.tmTheme" ]] \
    && printf '  theme: installed (restart Codex after changes)\n' || printf '  theme: missing\n'
  value="$(sed -n 's/^statusline=//p' "$mode_file" 2>/dev/null | head -1)"
  if [[ "$value" == enabled ]] && command -v tmux >/dev/null 2>&1; then
    printf '  statusline: Powerline enabled\n'
  elif [[ "$value" == enabled ]]; then
    printf '  statusline: blocked (tmux missing)\n'
  elif grep -q '^status_line[[:space:]]*=' "$CODEX_HOME/aicli-ultimate.config.toml" 2>/dev/null; then
    printf '  statusline: native Codex fallback enabled\n'
  else
    printf '  statusline: disabled\n'
  fi
  for value in jq sqlite3 git; do command -v "$value" >/dev/null 2>&1 || missing+=("$value"); done
  ((${#missing[@]})) \
    && printf '  optional metrics: limited (missing: %s)\n' "${missing[*]}" \
    || printf '  optional metrics: full\n'
  value="$(sed -n 's/^codex_skills=//p' "$mode_file" 2>/dev/null | head -1)"
  printf '  bundled skills: %s\n' "${value:-unknown}"
}

if [[ "${1:-}" == --doctor ]]; then
  doctor
  exit 0
fi

for argument in "$@"; do
  case "$argument" in
    -p|--profile|--profile=*) profile_args=(); break ;;
  esac
done

if [[ -z "$real_codex" || ! -x "$real_codex" ]]; then
  printf 'Codex CLI not found. Install Codex first: npm install -g @openai/codex\n' >&2
  exit 1
fi

statusline="$(sed -n 's/^statusline=//p' "$mode_file" 2>/dev/null | head -1)"
status_ready=1
command -v tmux >/dev/null 2>&1 || status_ready=0

case "${1:-}" in
  exec|review|resume|fork|archive|delete|unarchive|cloud|sandbox)
    exec "$real_codex" "${profile_args[@]}" "$@"
    ;;
  login|logout|mcp|plugin|mcp-server|app-server|remote-control|completion|update|doctor|debug|apply|exec-server|features|help|-h|--help|-V|--version)
    exec "$real_codex" "$@"
    ;;
esac

if [[ "$statusline" != "enabled" || "$status_ready" != 1 || ! -t 0 || ! -t 1 ]]; then
  exec "$real_codex" "${profile_args[@]}" "$@"
fi

session="aicli-ultimate-$$"
printf -v command '%q ' "$real_codex" "${profile_args[@]}" -c 'tui.status_line=[]' "$@"
exec env TMUX= tmux -L "aicli-ultimate-$$" -f "$tmux_config" \
  new-session -s "$session" -c "$PWD" "$command"
